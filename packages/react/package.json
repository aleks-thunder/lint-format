{
  "name": "@aleks-thunder/react",
  "version": "0.0.0",
  "description": "Shared React lint and format configuration",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleks-thunder/lint-and-formating.git"
  },
  "main": "eslint.js",
  "exports": {
    ".": "./eslint.js",
    "./eslint": "./eslint.js",
    "./prettier": "./prettier.js"
  },
  "files": [
    "eslint.js",
    "prettier.js"
  ],
  "dependencies": {
    "@aleks-thunder/base": "*",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "prettier-plugin-multiline-arrays": "4.1.5",
    "prettier-plugin-tailwindcss": "0.6.14"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "release": {
    "extends": "../../.releaserc.json",
    "tagFormat": "react-v${version}"
  }
}
