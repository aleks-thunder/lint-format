{
  "name": "@aleks-thunder/lint-format-react",
  "version": "0.0.0",
  "description": "Shared React lint and format configuration",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleks-thunder/lint-format.git"
  },
  "main": "eslint.config.js",
  "exports": {
    ".": "./eslint.config.js",
    "./eslint": "./eslint.config.js",
    "./prettier": "./prettier.config.js"
  },
  "files": [
    "eslint.config.js",
    "prettier.config.js"
  ],
  "dependencies": {
    "@aleks-thunder/lint-format-base": "*",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "prettier-plugin-tailwindcss": "0.6.14"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "release": {
    "extends": "../../.releaserc.json",
    "tagFormat": "react-v${version}"
  }
}


