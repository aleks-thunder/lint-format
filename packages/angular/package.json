{
  "name": "@aleks-thunder/lint-format-angular",
  "version": "1.0.0",
  "description": "Shared Angular lint and format configuration",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleks-thunder/lint-format.git"
  },
  "main": "eslint.config.js",
  "exports": {
    ".": "./eslint.config.js",
    "./eslint": "./eslint.config.js",
    "./prettier": "./prettier.config.js"
  },
  "files": [
    "eslint.config.js",
    "prettier.config.js"
  ],
  "dependencies": {
    "@aleks-thunder/lint-format-base": "*",
    "angular-eslint": "21.3.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "release": {
    "extends": "../../.releaserc.json",
    "tagFormat": "angular-v${version}"
  }
}
